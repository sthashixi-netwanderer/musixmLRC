{
  "name": "musixmlrc",
  "version": "1.0.0",
  "description": "Fetch synced lyrics from Musixmatch and save as .lrc files",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mxlrc": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "keywords": ["lyrics", "lrc", "musixmatch", "synced-lyrics"],
  "author": "fashni",
  "license": "MIT",
  "dependencies": {
    "music-metadata": "^10.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
